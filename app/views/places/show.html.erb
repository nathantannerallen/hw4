<div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-4">
  <div>
    <h1 class="mb-1"><%= @place["name"] %></h1>
    <h2 class="h4 text-muted mb-0">My Entries</h2>
  </div>

  <div class="d-flex gap-2">
    <% if @current_user != nil %>
      <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-primary">New Entry</a>
    <% end %>
    <a href="/places" class="btn btn-outline-secondary">Back to All Places</a>
  </div>
</div>

<div class="row g-4">
  <% for entry in @entries %>
    <div class="col-12 col-md-6 col-lg-4">
      <div class="card h-100">
        <div class="card-body">
          <h3 class="h5 card-title"><%= entry["title"] %></h3>
          <h4 class="h6 card-subtitle mb-3 text-muted"><%= entry["occurred_on"] %></h4>
          <p class="card-text mb-0"><%= entry["description"] %></p>
        </div>
      </div>
    </div>
  <% end %>
</div>
